# Токен бота от @BotFather
BOT_TOKEN=your_bot_token

# Ваш Telegram ID (числовой)
SUPERADMIN_ID=your_telegram_id

# URL подключения к PostgreSQL
# Для Docker Compose (локальный postgres):
#   postgresql+asyncpg://user:password@postgres:5432/bdsm_bot
# Для Managed PostgreSQL Timeweb Cloud — укажите хост из панели:
#   postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/bdsm_bot

# Часовой пояс (по умолчанию Europe/Moscow)
TIMEZONE=Europe/Moscow
